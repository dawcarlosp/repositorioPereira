{
  "compilerOptions": {
    // ── Entorno Vite + React ──────────────────────────────────────
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    // ── JSX ──────────────────────────────────────────────────────
    "jsx": "react-jsx",

    // ── Migración incremental JS → TS ────────────────────────────
    "allowJs": true,
    "checkJs": false,

    // ── Imports ──────────────────────────────────────────────────
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    // ── Output — Vite compila, TS solo verifica ───────────────────
    "noEmit": true,

    // ── Strictness ───────────────────────────────────────────────
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    // ── Paths — deben coincidir exactamente con vite.config.js ───
    "rootDir": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*":      ["./src/hooks/*"],
      "@pages/*":      ["./src/pages/*"],
      "@layout/*":     ["./src/layout/*"],
      "@context/*":    ["./src/context/*"],
      "@services/*":   ["./src/services/*"],
      "@buttons/*":    ["./src/components/common/buttons/*"],
      "@constants/*":  ["./src/constants/*"],
      "@utils/*":      ["./src/utils/*"],
      "@assets/*":     ["./src/assets/*"],
      "@domain/*":     ["./src/domain/*"]
    },

    // ── Misc ─────────────────────────────────────────────────────
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "vite.config.js"],
  "exclude": ["node_modules", "dist"]
}